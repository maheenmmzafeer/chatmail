# Gmail OAuth Credentials
# Get these from Google Cloud Console: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# NextAuth Configuration
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# Database
# For Supabase or Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/chatmail

# Google Cloud Pub/Sub (optional, for real-time updates)
GOOGLE_PUBSUB_TOPIC=projects/your-project-id/topics/gmail-watch
GOOGLE_PROJECT_ID=your-project-id

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
